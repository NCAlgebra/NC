Block[
  {x,y,vars,
   c1,m1,p1,
   c2,m2,p2,
   c3,m3,p3,
   list
   },

  (* Test NCPolySelectByLength *)

  Clear[x, y];
  vars={{x,y}};

  (* p1 = x                 (1 term)  *)
  c1={1};
  m1={{x}};
  p1=NCPoly[c1,m1,vars];

  (* p2 = x + x y           (2 terms) *)
  c2={1,1};
  m2={{x},{x,y}};
  p2=NCPoly[c2,m2,vars];

  (* p3 = x + x y + y x     (3 terms) *)
  c3={1,1,1};
  m3={{x},{x,y},{y,x}};
  p3=NCPoly[c3,m3,vars];

  NCTest[NCPolyNumberOfTerms[p1], 1];
  NCTest[NCPolyNumberOfTerms[p2], 2];
  NCTest[NCPolyNumberOfTerms[p3], 3];

  list = {p1, p2, p3};

  (* keep only those with at most maxLength terms *)
  NCTest[NCPolySelectByLength[list, 1], {p1}];
  NCTest[NCPolySelectByLength[list, 2], {p1, p2}];
  NCTest[NCPolySelectByLength[list, 3], {p1, p2, p3}];

  (* threshold below the smallest keeps nothing *)
  NCTest[NCPolySelectByLength[list, 0], {}];

  (* omitting maxLength defaults to Infinity: list unchanged *)
  NCTest[NCPolySelectByLength[list], list];

  (* empty list is returned unchanged *)
  NCTest[NCPolySelectByLength[{}, 5], {}];
  NCTest[NCPolySelectByLength[{}], {}];

];
